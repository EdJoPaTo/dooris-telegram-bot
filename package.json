{
	"name": "dooris-telegram-bot",
	"private": true,
	"license": "MIT",
	"scripts": {
		"start": "node --enable-source-maps source/dooris-telegram-bot.ts",
		"test": "tsc && xo"
	},
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"devEngines": {
		"packageManager": {
			"name": "npm"
		}
	},
	"dependencies": {
		"grammy": "^1.36.1",
		"telegraf-middleware-console-time": "^3.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"typescript": "^5.9.2",
		"xo": "^1.2.1"
	},
	"xo": {
		"rules": {
			"@typescript-eslint/naming-convention": "off",
			"unicorn/prevent-abbreviations": "off"
		}
	}
}
